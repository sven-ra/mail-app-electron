{
  "name": "electron-mail-viewer",
  "version": "1.0.0",
  "description": "Simple Electron IMAP email viewer",
  "main": "main.js",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron .",
    "dev": "concurrently \"vite\" \"NODE_ENV=development electron .\"",
    "watch": "concurrently \"vite\" \"NODE_ENV=development electronmon .\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tiptap/extension-underline": "3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "electron-store": "^8.1.0",
    "imap": "^0.8.19",
    "mailparser": "^3.6.5",
    "nodemailer": "^6.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-use": "^17.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electronmon": "^2.0.2",
    "typescript": "^6.0.3",
    "vite": "^5.0.0"
  }
}
