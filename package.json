{
  "name": "electron-mail-viewer",
  "version": "1.0.0",
  "description": "Simple Electron IMAP email viewer",
  "main": "main.js",
  "scripts": {
    "build": "vite build",
    "start": "npm run build && electron .",
    "dev": "concurrently \"vite\" \"NODE_ENV=development electron .\"",
    "watch": "concurrently \"vite\" \"NODE_ENV=development electronmon .\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "imap": "^0.8.19",
    "mailparser": "^3.6.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electronmon": "^2.0.2",
    "vite": "^5.0.0"
  }
}
